<Window x:Class="PodRelay.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="PodRelay"
        Icon="/PodRelay;component/Assets/airpods-app.ico"
        Width="760" Height="780" MinWidth="700" MinHeight="620"
        Background="{StaticResource PageBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="46" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0" />
    </shell:WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border BorderBrush="#FF202735" BorderThickness="0,0,0,1" Background="#FF0D1017">
            <Grid Margin="18,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="44" />
                </Grid.ColumnDefinitions>
                <Border Width="22" Height="22" CornerRadius="7" Background="{StaticResource AccentBrush}" VerticalAlignment="Center">
                    <TextBlock Text="P" Foreground="#FF08101D" FontWeight="Bold" FontSize="12"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Grid.Column="1" Text="PodRelay" FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="10,0,0,0" />
                <Button Grid.Column="2" Content="—" Click="OnMinimize" Style="{StaticResource QuietButton}"
                        Padding="0" Margin="0" FontSize="15" shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                <Button Grid.Column="3" Content="×" Click="OnWindowClose" Style="{StaticResource QuietButton}"
                        Padding="0" Margin="0" FontSize="20" shell:WindowChrome.IsHitTestVisibleInChrome="True" />
            </Grid>
        </Border>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="34,30,34,34">
            <StackPanel>
                <TextBlock Text="PODRELAY  ·  WINDOWS" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" />
                <TextBlock Text="AirPods，回到这台电脑" FontSize="33" FontWeight="SemiBold" Margin="0,9,0,7" />
                <TextBlock Text="一次确认连接、激活立体声音频，并把 Windows 输出切换过来。"
                           Style="{StaticResource CaptionText}" FontSize="15" Margin="0,0,0,24" />

                <Border CornerRadius="20" BorderThickness="1" BorderBrush="#FF30415B" Padding="22" Margin="0,0,0,14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF16243A" Offset="0" />
                            <GradientStop Color="#FF111824" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="当前状态" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                            <TextBlock x:Name="StatusText" Text="正在读取设备状态…" FontSize="18" FontWeight="SemiBold"
                                       Margin="0,5,16,0" TextWrapping="Wrap" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="连接 AirPods" Click="OnTestConnection"
                                Style="{StaticResource PrimaryButton}" MinWidth="142" Margin="0" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="PodRelay 要接力的耳机" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="选择要自动或手动连接的那一副耳机；通常只在首次设置或更换耳机时修改。"
                                           Style="{StaticResource CaptionText}" Margin="0,4,12,0" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="刷新" Click="OnRefreshDevices"
                                    Style="{StaticResource QuietButton}" Padding="14,8" Margin="0" />
                        </Grid>
                        <ComboBox x:Name="DeviceCombo" Height="43" Margin="0,16,0,0" DisplayMemberPath="Label" />
                        <TextBlock Text="列表只包含 Windows 已配对、并且拥有蓝牙音频输出端点的设备。"
                                   Style="{StaticResource CaptionText}" Margin="2,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="自动接力" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="适合没有其他输出设备的办公电脑；锁屏和用户冷却会始终优先。"
                                   Style="{StaticResource CaptionText}" Margin="0,4,0,8" />
                        <CheckBox x:Name="AutoRelayCheck" Content="发现耳机或没有可用音频输出时自动连接" />
                        <CheckBox x:Name="UnlockCheck" Content="Windows 登录或解锁后尝试连接" />
                        <CheckBox x:Name="ReconnectCheck" Content="连接意外丢失后按退避节奏重试" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="主动取消后的冷却时间" FontSize="14" />
                                <TextBlock Text="期间不会自动把耳机抢回来" Style="{StaticResource CaptionText}" Margin="0,3,0,0" />
                            </StackPanel>
                            <Grid Grid.Column="1">
                                <TextBox x:Name="CooldownText" TextAlignment="Right" Padding="8,9,30,9" />
                                <TextBlock Text="分" HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,10,0" Foreground="{StaticResource SecondaryTextBrush}" IsHitTestVisible="False" />
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="入耳检测" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="像 iPhone 一样控制 Windows 当前媒体；只会恢复由 PodRelay 自动暂停的内容。"
                                   Style="{StaticResource CaptionText}" Margin="0,4,0,8" />
                        <CheckBox x:Name="InEarMediaControlCheck"
                                  Content="取下一只自动暂停，重新戴上后继续播放" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="客厅与手柄" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Steam Input 可把 Guide + Y 映射到全局快捷键，无需注入游戏。"
                                   Style="{StaticResource CaptionText}" Margin="0,4,0,8" />
                        <CheckBox x:Name="PopupCheck" Content="显示适合远距离观看的 AirPods 接力弹窗" />
                        <CheckBox x:Name="ControllerRelayCheck" Content="绑定手柄接入时确保 AirPods 连接" />
                        <Grid Margin="0,8,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="ControllerCombo" Height="43" DisplayMemberPath="Label" />
                            <Button Grid.Column="1" Content="刷新手柄" Click="OnRefreshControllers"
                                    Style="{StaticResource QuietButton}" Padding="14,8" Margin="10,0,0,0" />
                        </Grid>
                        <TextBlock Text="先打开手柄再刷新并保存；以后该手柄接入会触发一次幂等接力。"
                                   Style="{StaticResource CaptionText}" Margin="2,4,0,8" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="135" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="78" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="全局快捷键" FontSize="14" />
                                <TextBlock Text="默认 Ctrl + Alt + A" Style="{StaticResource CaptionText}" Margin="0,3,0,0" />
                            </StackPanel>
                            <TextBox Grid.Column="1" x:Name="ModifiersText" ToolTip="例如 Control,Alt" />
                            <TextBox Grid.Column="3" x:Name="HotkeyText" TextAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="启动与隐私" Style="{StaticResource SectionTitle}" />
                            <CheckBox x:Name="StartupCheck" Content="登录 Windows 后在通知区域启动" Margin="0,9,0,4" />
                            <TextBlock Text="诊断日志只保存在 %LOCALAPPDATA%\PodRelay，不上传遥测。"
                                       Style="{StaticResource CaptionText}" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="导出诊断" Click="OnExportDiagnostics"
                                Style="{StaticResource QuietButton}" VerticalAlignment="Center" Margin="18,0,0,0" />
                    </Grid>
                </Border>

                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Content="预览大屏弹窗" Click="OnPreviewPopup" Style="{StaticResource QuietButton}"
                            HorizontalAlignment="Left" />
                    <Button Grid.Column="1" Content="保存设置" Click="OnSave" Style="{StaticResource PrimaryButton}"
                            MinWidth="126" Margin="0" />
                </Grid>
            </StackPanel>
        </Grid>
        </ScrollViewer>
    </Grid>
</Window>
